#!/usr/bin/env bash

GIGSREQD=95 # 56

gigsfree() { df . -BG --output=avail | tail -n1 | sed 's/[^0-9]//g'; }
msg() { echo $GIGSREQD GB NEEDED, $1 GB AVAILABLE: $2; }

initial=$(gigsfree)

if [[ $initial -ge $GIGSREQD ]]; then
  msg $initial OK
else
  msg $initial CLEANING
  removable=(
    'docker-*'
    'gcc-12'
    'gcc-13'
    'gcc-14'
    'gfortran-*'
    'google-*'
    'llvm-*'
    'microsoft-*'
    'mysql-*'
    'postgresql-*'
    'python3-boto*'
    'temurin-*'
    ant
    azure-cli
    containerd.io
    firefox
    gfortran
    gh
    kubectl
    podman
    powershell
    snapd
  )
  sudo apt remove -y ${removable[@]} | grep --line-buffered -v "is not installed"
  sudo apt autoremove -y
  sudo apt clean -y
  sudo rm -rf /usr/lib/{firefox,google-cloud-sdk,jvm,snapd} /usr/share/{az_*,dotnet,gradle-*,kotlinc,miniconda,swift} /usr/local/{aws-*,julia*} /usr/local/share/{chromium,powershell} /opt/{az,google,microsoft,pipx} /home/runner/{.cargo,.dotnet,.rustup} /usr/local/lib/android
  sudo rm -rf /opt/hostedtoolcache/{Ruby,PyPy,node,go,CodeQL}
  (
    set -x
    #du -BM -s /home/runner/* | sort -n
    #du -BM -s /home/runner/.* | sort -n
    #du -BM -s /opt/* | sort -n
    #du -BM -s /opt/hostedtoolcache/* | sort -n
    #du -BM -s /usr/lib/* | sort -n
    #du -BM -s /usr/local/* | sort -n
    #du -BM -s /usr/local/lib/* | sort -n
    #du -BM -s /usr/local/share/* | sort -n
    #du -BM -s /usr/share/* | sort -n
  ) || true
  final=$(gigsfree)
  reclaimed=$(( final - initial ))
  echo RECLAIMED $reclaimed GB
  if [[ $final -lt $GIGSREQD ]]; then
    msg $final STOPPING
    exit 1
  fi
  msg $final OK
fi
