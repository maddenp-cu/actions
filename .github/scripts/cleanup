#!/usr/bin/env bash

GIGSREQD=95 # 56

gigsfree() { df . -BG --output=avail | tail -n1 | sed 's/[^0-9]//g'; }
msg() { echo $GIGSREQD GB NEEDED, $1 GB AVAILABLE: $2; }

initial=$(gigsfree)

if [[ $initial -ge $GIGSREQD ]]; then
  msg $initial OK
else
  msg $initial CLEANING
  (set -x && apt list --installed) # PM FIXME
  removable=(
    '*jdk*'
    'docker-*'
    'gcc-12'
    'gcc-13'
    'gfortran-*'
    'llvm-*'
    'mysql-client-*'
    'mysql-server-core-*'
    'postgresql-*'
    'temurin-*'
    azure-cli
    containerd.io
    firefox
    gh
    google-chrome-stable
    google-cloud-cli
    google-cloud-cli-anthoscli
    kubectl
    microsoft-edge-stable
    podman
    powershell
    python3-botocore
    snapd
    'llvm-*'
    gradle
    miniconda
    
  )
  sudo apt remove -y ${removable[@]} | grep --line-buffered -v "is not installed"
  sudo apt autoremove -y
  sudo apt clean -y
  (
    set -x
    du -BM -s /usr/lib/* | sort -n
    du -BM -s /usr/share/* | sort -n
    du -BM -s /usr/local/* | sort -n
    du -BM -s /home/runner/* | sort -n
    du -BM -s /usr/local/lib/* | sort -n
    du -BM -s /usr/local/share/* | sort -n
    du -BM -s /opt/* | sort -n
  ) || true
  final=$(gigsfree)
  reclaimed=$(( final - initial ))
  echo RECLAIMED $reclaimed GB
  if [[ $final -lt $GIGSREQD ]]; then
    msg $final STOPPING
    exit 1
  fi
  msg $final OK

fi
